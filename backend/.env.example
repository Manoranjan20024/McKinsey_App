# Scanify AI - Backend Environment Configuration

# 1. AI API Configuration (MANDATORY)
# Get your API key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Server Configuration
PORT=8000
HOST=0.0.0.0

# 3. Knowledge Base Configuration
# Path to the ChromaDB vector store
CHROMA_DB_PATH=./rag_setup/chroma_db
KNOWLEDGE_BASE_DIR=./rag_setup/knowledge_base
